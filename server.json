{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Roberton003/mcp-server-decisions",
  "description": "Decision tracking with prediction validation and outcome gates for AI agents",
  "repository": {
    "url": "https://github.com/Roberton003/mcp-server-decisions",
    "source": "github"
  },
  "version": "1.0.2",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "mcp-server-decisions",
      "version": "1.0.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Path to decisions log file (default: ~/.local/share/mcp-decisions/decisions_log.json)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "MCP_DECISIONS_LOG_PATH"
        }
      ]
    }
  ]
}